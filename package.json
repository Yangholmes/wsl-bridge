{
  "name": "wsl-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "WSL Bridge is a Windows desktop application that helps you easily expose WSL and Hyper-V virtual machine network services to external networks. Supports TCP/UDP port forwarding, HTTP proxy and SOCKS5 proxy, with intuitive rule management and firewall configuration.",
  "author": "yangholmes",
  "license": "MIT",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "typecheck": "tsc --noEmit",
    "tauri": "node scripts/tauri-runner.mjs"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "@microsoft/clarity": "^1.0.2",
    "@solid-primitives/i18n": "^2.2.1",
    "@tanstack/solid-query": "^5.90.3",
    "@tanstack/solid-router": "^1.140.1",
    "@tanstack/solid-table": "^8.21.3",
    "@tauri-apps/api": "^2.8.0",
    "solid-js": "^1.9.9",
    "uplot": "^1.6.31"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.2",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.11",
    "vite-plugin-solid": "^2.11.8"
  }
}
