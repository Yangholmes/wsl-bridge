{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WSL Bridge",
  "version": "0.1.0",
  "identifier": "com.wsl.bridge",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WSL Bridge",
        "width": 1026,
        "height": 768,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.ico"]
  }
}
